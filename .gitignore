*.log

# Local data cache (do NOT commit competition datasets — Kaggle ToS).
# oracle_preds.parquet is the one intentional exception (committed: pre-computed
# submission values, used as a portability oracle). Everything else parquet is gitignored.
*.parquet
!oracle_preds.parquet

